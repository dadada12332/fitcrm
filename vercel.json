{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["syd1"],
  "crons": [
    {
      "path": "/api/telegram/daily-report",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/telegram/reminders/run",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/reconcile",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/telegram/client-support/run",
      "schedule": "*/10 * * * *"
    }
  ]
}
