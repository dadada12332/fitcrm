# ─────────────────────────────────────────────────────────────
# FitCRM — шаблон переменных окружения.
#
# НИКОГДА не коммитьте реальный .env.local (он в .gitignore).
# На новом ПК самый простой способ получить все значения:
#   npm i -g vercel && vercel link && vercel env pull .env.local
# (Vercel — единый источник правды по секретам, раз прод там задеплоен.)
#
# Либо скопируйте этот файл в .env.local и заполните значения вручную.
# ─────────────────────────────────────────────────────────────

# ── Supabase (Dashboard → Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # секрет! обходит RLS
SUPABASE_ACCESS_TOKEN=              # для scripts/apply-migration.mjs (Management API)

# ── Приложение ──
NEXT_PUBLIC_APP_URL=https://fitcrm-three.vercel.app
NEXT_PUBLIC_ADMIN_URL=
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── AI ──
GEMINI_API_KEY=                     # чат-ассистент /ai
ANTHROPIC_API_KEY=                  # AI-аналитика в Telegram-боте

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CRM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_SETUP_SECRET=

# ── Instagram / Meta ──
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=               # секрет Meta App
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=     # произвольный секрет проверки webhook
META_GRAPH_API_VERSION=v25.0

# ── Google Calendar ──
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=      # секрет OAuth Web application
GOOGLE_CALENDAR_REDIRECT_URI=       # опционально; по умолчанию NEXT_PUBLIC_APP_URL/api/integrations/google-calendar/callback

# ── Платежи / шифрование ──
PAYMENT_ENC_KEY=                    # ключ шифрования платёжных реквизитов (AES)
QR_SIGNING_SECRET=                  # опциональный отдельный HMAC-ключ динамических QR

# ── Cron ──
CRON_SECRET=                        # защита /api/cron/* и /api/broadcasts/run
