# FitCRM Telegram Agent — переменные окружения (скопируй в .env, НЕ коммить)

# Токен ОТДЕЛЬНОГО бота для агентов (создай через @BotFather).
# Не переиспользуй боевой TELEGRAM_CRM_BOT_TOKEN клуба — это другой контур.
TELEGRAM_AGENT_BOT_TOKEN=

# Кто может ставить задачи. Через запятую: твой user_id и/или id группы.
# Узнать свой id — напиши боту @userinfobot. Для группы id обычно отрицательный.
# КРИТИЧНО для безопасности: пустой список = никого не пускает.
TELEGRAM_ALLOWED_IDS=

# Ключ Claude (агентный движок). Каждая задача тратит токены.
ANTHROPIC_API_KEY=

# Необязательно:
# PROJECT_DIR=/abs/path/to/fitcrm     # по умолчанию — родительская папка воркера
# CLAUDE_BIN=claude                   # путь к бинарю Claude Code, если не в PATH
# AGENT_MODEL=claude-opus-4-8         # модель лида; пусто = дефолт CLI
